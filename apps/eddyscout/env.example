# Copy to .local.env and fill in (never commit .local.env):
#   cp env.example .local.env
#
# Mapbox public token: https://account.mapbox.com/access-tokens/
# Restrict by bundle ID in Mapbox before shipping.

MAPBOX_ACCESS_TOKEN=

# Uncomment when android/app/google-services.json is in place and functions are deployed:
# USE_FIREBASE=true

# Flutter: optional Firebase (condition reports + AI summary Callables).
# Default is off so `flutter test` and builds without Firebase config work.
# With Firebase: add android/app/google-services.json (and iOS plist when you add iOS),
# enable Anonymous sign-in in Firebase Console, deploy `firebase/functions`, then either:
#   USE_FIREBASE=true in .local.env (picked up by `make run` / ./scripts/run_android.sh), or:
#   flutter run --dart-define=USE_FIREBASE=true --dart-define=MAPBOX_ACCESS_TOKEN=...
#
# Anthropic API key is NOT here — set only in Cloud Functions:
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#
# That command needs the Firebase project on the Blaze (pay-as-you-go) plan so
# Google Secret Manager can be enabled. Blaze still includes generous free quotas;
# a personal MVP with almost no traffic usually stays at $0—set a budget alert in
# Google Cloud Console if you want peace of mind.
#
# If `firebase deploy` fails with “missing permission on the build service account”,
# see firebase/DEPLOY.md (IAM fix + optional gcloud one-liner).
