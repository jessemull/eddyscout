{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "eddyscout (Mapbox token from env)",
      "request": "launch",
      "type": "dart",
      "program": "apps/eddyscout/lib/main.dart",
      "cwd": "${workspaceFolder}/apps/eddyscout",
      "args": [
        "--dart-define=MAPBOX_ACCESS_TOKEN=${env:MAPBOX_ACCESS_TOKEN}"
      ]
    },
    {
      "name": "eddyscout (no token — setup screen)",
      "request": "launch",
      "type": "dart",
      "program": "apps/eddyscout/lib/main.dart",
      "cwd": "${workspaceFolder}/apps/eddyscout"
    }
  ]
}
